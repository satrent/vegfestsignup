# Basecamp OAuth 2 credentials — copy this file to `.env` and fill in.
# `.env` is git-ignored; never commit real secrets.

# From the Launchpad app detail page ("Trent Claude")
BASECAMP_CLIENT_ID=
BASECAMP_CLIENT_SECRET=

# Must EXACTLY match the Redirect URI you registered on Launchpad.
BASECAMP_REDIRECT_URI=http://localhost:3000/auth

# Your Basecamp account id (from the URL: 3.basecamp.com/<ACCOUNT_ID>)
BASECAMP_ACCOUNT_ID=4752465

# Basecamp requires a descriptive User-Agent with a contact email.
BASECAMP_USER_AGENT=VegFest Signup (trent01@gmail.com)

# --- Filled in automatically by auth.mjs after you authorize ---
BASECAMP_ACCESS_TOKEN=
BASECAMP_REFRESH_TOKEN=
BASECAMP_TOKEN_EXPIRES_AT=
